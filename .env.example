# Server
PORT=8080
WEB_DIST=./web/dist
LOG_LEVEL=info

# Database (required for deploy)
DATABASE_URL=postgres://user:password@localhost:5432/todo?sslmode=disable

# Auth (required for production)
JWT_SECRET=your-secret-key-change-in-production

# Notifier microservice (optional)
NOTIFIER_INTERVAL_MINUTES=10
NOTIFIER_DEDUPE_HOURS=24
